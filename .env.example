# Copy to .env and fill in. .env is gitignored.
WEBSITE_DEMO_PASSWORD=changeme
ANTHROPIC_API_KEY=sk-ant-...
# Secret used to sign the auth cookie (HMAC). Optional locally (falls back to the
# demo password); set a distinct long random value in production.
SESSION_SECRET=
# Runtime error alerting -> Discord (fires in production by default)
DISCORD_WEBHOOK_URL=
# Force alerts on/off regardless of NODE_ENV: true | false
# DISCORD_ALERTS=true

# Optional overrides
# ANTHROPIC_MODEL=claude-opus-4-8
# API_PORT=8787
